# ============================================================
# PORT GROUP MANAGEMENT
# ============================================================

pg_validate_port_token() {
  # Accept single port or range (same rules as is_valid_port_or_range)
  is_valid_port_or_range "$1"
}

pg_add_ports_loop() {
  # Interactive loop — user adds one port/range at a time
  # Returns list of validated tokens via stdout, one per line
  local token
  while true; do
    tread token "  Add port or range (blank = done): " || break
    [ -z "$token" ] && break
    if pg_validate_port_token "$token"; then
      echo "$token"
    else
      tprint "  ERROR: '$token' is not a valid port or range (1-65535). Try again."
    fi
  done
}

pg_add_ports_csv() {
  # Single comma-separated input — splits and validates each token
  # Returns validated tokens via stdout, one per line
  local raw token
  tread raw "  Enter ports/ranges comma-separated (e.g. 80,443,8000-8080): " || return 0
  [ -z "$raw" ] && return 0
  # Split on commas using tr
  printf "%s" "$raw" | tr ',' '\n' | while IFS= read -r token; do
    token="$(printf "%s" "$token" | tr -d ' ')"   # strip spaces
    [ -z "$token" ] && continue
    if pg_validate_port_token "$token"; then
      echo "$token"
    else
      tprint "  ERROR: '$token' invalid — skipped (must be port 1-65535 or range lo-hi)."
    fi
  done
}

pg_collect_ports() {
  # Offer both input modes; returns validated port tokens via stdout
  tprint ""
  select_from_list_default "How do you want to add ports?" "one at a time" \
    "one at a time" "comma-separated list" || return 0

  case "$SELECTED" in
    "one at a time")
      tprint "  (Enter blank line when finished)"
      pg_add_ports_loop
      ;;
    "comma-separated list")
      pg_add_ports_csv
      ;;
  esac
}

pg_list_all() {
  local groups=()
  load_array groups scan_port_groups
  tprint ""
  tprint "=== Port Groups ==="
  if [ "${#groups[@]}" -eq 0 ]; then
    tprint "  (none defined)"
  else
    print_port_groups_inline
  fi
  tprint ""
  pause
}

pg_create_safe() {
  local existing=() name ports=() yn

  load_array existing scan_port_groups

  tprint ""
  tprint "=== Create Port Group ==="
  tprint "Existing groups: ${existing[*]:-(none)}"
  tprint ""

  # Name
  name="$(ask "New group name (e.g. WEB-PORTS, AD-TCP)" "")"
  [ -z "$name" ] && return 0
  if ! is_safe_ruleset_name "$name"; then
    tprint "ERROR: Invalid name — letters/numbers/_/./- max 64."; pause; return 0
  fi
  if is_in_list "$name" "${existing[@]}"; then
    tprint "ERROR: Group '$name' already exists. Use Edit to modify it."; pause; return 0
  fi

  # Ports
  tprint ""
  tprint "Add ports to group '$name':"
  load_array ports pg_collect_ports

  if [ "${#ports[@]}" -eq 0 ]; then
    tprint "ERROR: No valid ports entered. Group not created."; pause; return 0
  fi

  # Summary
  tprint ""
  tprint "SUMMARY: create port-group '$name'"
  tprint "  ports: ${ports[*]}"
  tprint ""
  yn="$(choose_yes_no "Proceed?" "y" || echo "n")"
  [ "$yn" != "y" ] && { tprint "Canceled."; pause; return 0; }

  cfg_begin || return 0
  local p
  for p in "${ports[@]}"; do
    cfg_set firewall group port-group "$name" port "$p"
  done
  cfg_apply
}

pg_edit_members() {
  local existing=() grp members=() yn

  load_array existing scan_port_groups
  require_nonempty_list_or_return "port groups" "${existing[@]}" || return 0

  tprint ""
  tprint "=== Edit Port Group Members ==="
  tprint "Groups (name + members):"
  print_port_groups_inline
  tprint ""

  select_from_list "Select port group to edit" "${existing[@]}" || return 0
  grp="$SELECTED"

  load_array members scan_port_group_members "$grp"
  tprint ""
  tprint "Current members of '$grp': ${members[*]:-(empty)}"
  tprint ""

  select_from_list_default "Edit action" "add ports" \
    "add ports" "remove a port" || return 0

  case "$SELECTED" in
    "add ports")
      local new_ports=()
      tprint ""
      tprint "Add ports to '$grp':"
      load_array new_ports pg_collect_ports

      if [ "${#new_ports[@]}" -eq 0 ]; then
        tprint "No ports entered. Nothing changed."; pause; return 0
      fi

      # Filter out already-existing members
      local to_add=() p
      for p in "${new_ports[@]}"; do
        if is_in_list "$p" "${members[@]}"; then
          tprint "  NOTE: port '$p' already in group — skipped."
        else
          to_add+=("$p")
        fi
      done

      if [ "${#to_add[@]}" -eq 0 ]; then
        tprint "All entered ports already exist in group."; pause; return 0
      fi

      tprint ""
      tprint "SUMMARY: add to '$grp': ${to_add[*]}"
      yn="$(choose_yes_no "Proceed?" "y" || echo "n")"
      [ "$yn" != "y" ] && { tprint "Canceled."; pause; return 0; }

      cfg_begin || return 0
      for p in "${to_add[@]}"; do
        cfg_set firewall group port-group "$grp" port "$p"
      done
      cfg_apply
      ;;

    "remove a port")
      require_nonempty_list_or_return "ports in '$grp'" "${members[@]}" || return 0
      select_from_list "Select port to REMOVE from '$grp'" "${members[@]}" || return 0
      local target="$SELECTED"

      tprint ""
      tprint "SUMMARY: remove port '$target' from group '$grp'"
      if [ "${#members[@]}" -le 1 ]; then
        tprint "WARNING: This is the last port. Group will be empty after removal."
        tprint "         VyOS may reject an empty port-group at commit."
      fi
      yn="$(choose_yes_no "Proceed?" "n" || echo "n")"
      [ "$yn" != "y" ] && { tprint "Canceled."; pause; return 0; }

      cfg_begin || return 0
      cfg_delete firewall group port-group "$grp" port "$target"
      cfg_apply
      ;;
  esac
}

pg_delete_safe() {
  local existing=() grp yn

  load_array existing scan_port_groups
  require_nonempty_list_or_return "port groups" "${existing[@]}" || return 0

  tprint ""
  tprint "=== Delete Port Group ==="
  tprint "Groups (name + members):"
  print_port_groups_inline
  tprint ""

  select_from_list "Select port group to DELETE" "${existing[@]}" || return 0
  grp="$SELECTED"

  # Check if referenced in any ruleset
  local refs
  refs="$(grep_cfg "port-group '$grp'" | grep -v "set firewall group" | head -n 5 || true)"
  [ -z "$refs" ] && refs="$(grep_cfg "port-group $grp" | grep -v "set firewall group" | head -n 5 || true)"

  tprint ""
  if [ -n "$refs" ]; then
    tprint "WARNING: Group '$grp' is referenced in firewall/NAT rules:"
    printf "%s\n" "$refs" >"$TTY"
    tprint "Deleting it will leave those rules with a broken group reference."
    tprint ""
  fi

  tprint "About to DELETE port-group: $grp"
  tprint "Members: $(scan_port_group_members "$grp" | join_lines || echo "(empty)")"
  tprint ""
  yn="$(choose_yes_no "Proceed?" "n" || echo "n")"
  [ "$yn" != "y" ] && { tprint "Canceled."; pause; return 0; }

  cfg_begin || return 0
  cfg_delete firewall group port-group "$grp"
  cfg_apply
}

port_group_menu() {
  warn_if_no_access || return 0
  while true; do
    tprint ""
    tprint "=============================="
    tprint " Port Group Management"
    tprint "=============================="
    tprint "Groups:"
    print_port_groups_inline
    tprint ""
    tprint "1) List all port groups (detailed)"
    tprint "2) Create port group"
    tprint "3) Edit group members (add / remove ports)"
    tprint "4) Delete port group"
    tprint "5) Back"
    local c; tread c "Select: " || continue
    case "$c" in
      1) pg_list_all ;;
      2) pg_create_safe ;;
      3) pg_edit_members ;;
      4) pg_delete_safe ;;
      5) return 0 ;;
      *) tprint "Invalid." ;;
    esac
  done
}

# ============================================================
# INSERT POINT 3:
# REPLACE fw_add_rule_guided_safe with this updated version
# (adds group-aware pickers for saddr, daddr, sport, dport)
# ============================================================

fw_add_rule_guided_safe() {
  local rs n action proto desc yn
  local saddr_result="" daddr_result="" sport_result="" dport_result=""
  local state_est state_rel state_new

  tprint ""; tprint "ADD firewall rule (safe — new rule number only)"
  rs="$(fw_choose_ruleset_or_new)" || return 0
  n="$(fw_choose_rule_number_new_only "$rs")" || return 0
  tprint ""; tprint "Creating: $rs rule $n — fill optional fields or leave blank."

  action="$(choose_fw_action "accept")"   || return 0
  proto="$(choose_fw_protocol "tcp")"     || return 0

  desc="$(ask "Description (optional)" "")"
  [ -n "$desc" ] && ! is_safe_free_text "$desc" && {
    tprint "ERROR: Invalid description."; pause; return 0
  }

  # --- Source address (plain or group) ---
  saddr_result="$(choose_addr_or_group_field "source" "")"
  [ -z "$saddr_result" ] && saddr_result=""

  # --- Destination address (plain or group) ---
  daddr_result="$(choose_addr_or_group_field "destination" "")"
  [ -z "$daddr_result" ] && daddr_result=""

  # --- Source port (plain or group) ---
  sport_result="$(choose_port_or_group_field "source" "")"
  [ -z "$sport_result" ] && sport_result=""

  # --- Destination port (plain or group) ---
  dport_result="$(choose_port_or_group_field "destination" "")"
  [ -z "$dport_result" ] && dport_result=""

  state_est="$(choose_yes_no "Match ESTABLISHED?" "n" || echo "n")"
  state_rel="$(choose_yes_no "Match RELATED?"     "n" || echo "n")"
  state_new="$(choose_yes_no "Match NEW?"         "n" || echo "n")"

  # Summary
  tprint ""; tprint "SUMMARY: $rs rule $n  action=$action  proto=$proto"
  [ -n "$saddr_result" ] && tprint "  src-addr:  $saddr_result"
  [ -n "$sport_result" ] && tprint "  src-port:  $sport_result"
  [ -n "$daddr_result" ] && tprint "  dst-addr:  $daddr_result"
  [ -n "$dport_result" ] && tprint "  dst-port:  $dport_result"
  [ -n "$desc"         ] && tprint "  desc:      $desc"
  tprint ""

  yn="$(choose_yes_no "Create this rule?" "y" || echo "n")"
  [ "$yn" != "y" ] && { tprint "Canceled."; pause; return 0; }

  cfg_begin || return 0

  local existing_rs=()
  load_array existing_rs scan_firewall_rulesets
  if ! is_in_list "$rs" "${existing_rs[@]}"; then
    tprint "New ruleset '$rs' — setting default-action drop."
    cfg_set firewall ipv4 name "$rs" default-action drop
  fi

  cfg_set firewall ipv4 name "$rs" rule "$n" action "$action"
  [ -n "$desc"  ] && cfg_set firewall ipv4 name "$rs" rule "$n" description "$desc"
  [ -n "$proto" ] && [ "$proto" != "any" ] && \
    cfg_set firewall ipv4 name "$rs" rule "$n" protocol "$proto"

  # Apply address/port results
  [ -n "$saddr_result" ] && apply_addr_picker_result firewall "$rs" "$n" source      "$saddr_result"
  [ -n "$daddr_result" ] && apply_addr_picker_result firewall "$rs" "$n" destination "$daddr_result"
  [ -n "$sport_result" ] && apply_port_picker_result firewall "$rs" "$n" source      "$sport_result"
  [ -n "$dport_result" ] && apply_port_picker_result firewall "$rs" "$n" destination "$dport_result"

  { [ "$state_est" = "y" ] || [ "$state_est" = "Y" ]; } && \
    cfg_set firewall ipv4 name "$rs" rule "$n" state established
  { [ "$state_rel" = "y" ] || [ "$state_rel" = "Y" ]; } && \
    cfg_set firewall ipv4 name "$rs" rule "$n" state related
  { [ "$state_new" = "y" ] || [ "$state_new" = "Y" ]; } && \
    cfg_set firewall ipv4 name "$rs" rule "$n" state new

  cfg_apply
}

